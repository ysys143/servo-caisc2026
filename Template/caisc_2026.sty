% LaTeX2e style file for submissions to the
% Conference For AI Scientists (CAISc 2026):
%
% - Based on the agents4science 2025 style file, itself derived from
%   the NeurIPS 2025 style file by Roman Garnett et al.
% - Conference name, year, and details updated for CAISc 2026
% - Internal macro prefix renamed from \@agents* to \@caisc*
% - Submission and camera-ready notice strings updated for CAISc
% - Camera-ready footer changed to "Published at" (was just conference name)
% - Fixed typo in \involvmentTODO macro (renamed to \involvementTODO)
% - Workshop option declarations commented out (not needed for inaugural edition)
% - Added iteration effort macros: \iterationLow, \iterationMedium, \iterationHigh, \iterationNA, \iterationUnclear, \iterationTODO
%
% Last revision: 14 April 2026

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{caisc_2026}[2026/04/04 CAISc 2026 submission/camera-ready style file]

% declare final option, which creates camera-ready copy
\newif\if@caiscfinal\@caiscfinalfalse
\DeclareOption{final}{
  \@caiscfinaltrue
  \@anonymousfalse
}

% declare nonatbib option, which does not load natbib in case of
% package clash (users can pass options to natbib via
% \PassOptionsToPackage)
\newif\if@natbib\@natbibtrue
\DeclareOption{nonatbib}{
  \@natbibfalse
}

% declare preprint option, which creates a preprint version ready for
% upload to, e.g., arXiv
\newif\if@preprint\@preprintfalse
\DeclareOption{preprint}{
  \@preprinttrue
  \@anonymousfalse
}

% determine the track of the paper in camera-ready mode
\newif\if@main\@maintrue
\DeclareOption{main}{
  \@maintrue
  \newcommand{\@trackname}{\@caiscordinal\ Conference For AI Scientists (CAISc \@caiscyear).}
}

% For anonymous or non-anonymous
\newif\if@anonymous\@anonymoustrue

% Workshop options — commented out for CAISc 2026 (no workshops in the
% inaugural edition). Uncomment and update when the conference expands
% to include workshop tracks.
