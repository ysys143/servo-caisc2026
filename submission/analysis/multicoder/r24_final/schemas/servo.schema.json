{
  "$defs": {
    "CommonEnvelope": {
      "additionalProperties": false,
      "properties": {
        "diagnostics": {
          "items": {
            "$ref": "#/$defs/Diagnostic"
          },
          "title": "Diagnostics",
          "type": "array"
        },
        "recommendations": {
          "items": {
            "$ref": "#/$defs/Recommendation"
          },
          "maxItems": 3,
          "minItems": 1,
          "title": "Recommendations",
          "type": "array"
        }
      },
      "required": [
        "diagnostics",
        "recommendations"
      ],
      "title": "CommonEnvelope",
      "type": "object"
    },
    "DecisionRole": {
      "enum": [
        "diagnostic",
        "ranking",
        "search_control",
        "stage_transition",
        "memory_admission",
        "terminal_assessment",
        "final_acceptance",
        "external_assessment",
        "not_reported"
      ],
      "title": "DecisionRole",
      "type": "string"
    },
    "Diagnostic": {
      "additionalProperties": false,
      "properties": {
        "consequence": {
          "minLength": 1,
          "title": "Consequence",
          "type": "string"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Evidence Ids",
          "type": "array"
        },
        "exact_quotes": {
          "items": {
            "$ref": "#/$defs/EvidenceExcerpt"
          },
          "minItems": 1,
          "title": "Exact Quotes",
          "type": "array"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/DiagnosticKind"
        },
        "statement": {
          "minLength": 1,
          "title": "Statement",
          "type": "string"
        }
      },
      "required": [
        "id",
        "statement",
        "kind",
        "evidence_ids",
        "exact_quotes",
        "consequence"
      ],
      "title": "Diagnostic",
      "type": "object"
    },
    "DiagnosticKind": {
      "enum": [
        "reported_failure",
        "risk",
        "ambiguity",
        "missing_evidence"
      ],
      "title": "DiagnosticKind",
      "type": "string"
    },
    "EvaluatorSubstrate": {
      "enum": [
        "deterministic_program",
        "statistical_model",
        "formal_kernel",
        "llm",
        "human",
        "hybrid",
        "not_reported"
      ],
      "title": "EvaluatorSubstrate",
      "type": "string"
    },
    "EvidenceExcerpt": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "exact_quote": {
          "minLength": 1,
          "title": "Exact Quote",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "exact_quote"
      ],
      "title": "EvidenceExcerpt",
      "type": "object"
    },
    "EvidenceQuote": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "page": {
          "minimum": 1,
          "title": "Page",
          "type": "integer"
        },
        "pdf_id": {
          "minLength": 1,
          "title": "Pdf Id",
          "type": "string"
        },
        "quote": {
          "minLength": 1,
          "title": "Quote",
          "type": "string"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "pdf_id",
        "page",
        "quote",
        "rationale"
      ],
      "title": "EvidenceQuote",
      "type": "object"
    },
    "EvidenceSource": {
      "enum": [
        "execution_trace",
        "benchmark_metric",
        "statistical_test",
        "physical_measurement",
        "replication",
        "prior_art_corpus",
        "artifact_review",
        "human_judgment",
        "not_reported"
      ],
      "title": "EvidenceSource",
      "type": "string"
    },
    "ExternalIndependence": {
      "enum": [
        "internal_self_evaluation",
        "internal_separate_component",
        "external_nonindependent",
        "external_independent",
        "not_reported"
      ],
      "title": "ExternalIndependence",
      "type": "string"
    },
    "FeedbackPath": {
      "enum": [
        "terminal_only",
        "memory_update",
        "candidate_revision",
        "policy_control",
        "stage_transition",
        "external_only",
        "unclear"
      ],
      "title": "FeedbackPath",
      "type": "string"
    },
    "Fidelity": {
      "enum": [
        "simulation_or_proxy",
        "computational_experiment",
        "computational_oracle_or_benchmark",
        "robotic_experiment",
        "physical_assay",
        "not_applicable",
        "not_reported"
      ],
      "title": "Fidelity",
      "type": "string"
    },
    "HumanAuthority": {
      "additionalProperties": false,
      "properties": {
        "executor": {
          "items": {
            "type": "string"
          },
          "title": "Executor",
          "type": "array"
        },
        "generator": {
          "items": {
            "type": "string"
          },
          "title": "Generator",
          "type": "array"
        },
        "memory": {
          "items": {
            "type": "string"
          },
          "title": "Memory",
          "type": "array"
        },
        "policy": {
          "items": {
            "type": "string"
          },
          "title": "Policy",
          "type": "array"
        },
        "validator": {
          "items": {
            "type": "string"
          },
          "title": "Validator",
          "type": "array"
        }
      },
      "required": [
        "generator",
        "executor",
        "validator",
        "memory",
        "policy"
      ],
      "title": "HumanAuthority",
      "type": "object"
    },
    "OperationalStatus": {
      "enum": [
        "implemented",
        "proposed_not_exercised",
        "external",
        "not_reported",
        "unclear"
      ],
      "title": "OperationalStatus",
      "type": "string"
    },
    "Recommendation": {
      "additionalProperties": false,
      "properties": {
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Evidence Ids",
          "type": "array"
        },
        "exact_quotes": {
          "items": {
            "$ref": "#/$defs/EvidenceExcerpt"
          },
          "minItems": 1,
          "title": "Exact Quotes",
          "type": "array"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "linked_diagnostic_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Linked Diagnostic Ids",
          "type": "array"
        },
        "priority_rank": {
          "maximum": 3,
          "minimum": 1,
          "title": "Priority Rank",
          "type": "integer"
        },
        "proposed_action": {
          "minLength": 1,
          "title": "Proposed Action",
          "type": "string"
        },
        "success_check": {
          "$ref": "#/$defs/SuccessCheck"
        }
      },
      "required": [
        "id",
        "priority_rank",
        "proposed_action",
        "linked_diagnostic_ids",
        "evidence_ids",
        "exact_quotes",
        "success_check"
      ],
      "title": "Recommendation",
      "type": "object"
    },
    "ReliabilityEvidence": {
      "enum": [
        "none_reported",
        "discrimination_study",
        "agreement_study",
        "systematic_error_or_bias_test",
        "property_specific_external_validation",
        "probabilistic_calibration_analysis"
      ],
      "title": "ReliabilityEvidence",
      "type": "string"
    },
    "ReliabilityFinding": {
      "enum": [
        "not_evaluated",
        "not_established",
        "evidence_of_error_or_bias",
        "positive_property_specific_evidence",
        "mixed",
        "unclear"
      ],
      "title": "ReliabilityFinding",
      "type": "string"
    },
    "SuccessCheck": {
      "additionalProperties": false,
      "properties": {
        "comparator_or_threshold": {
          "minLength": 1,
          "title": "Comparator Or Threshold",
          "type": "string"
        },
        "evidence_needed": {
          "minLength": 1,
          "title": "Evidence Needed",
          "type": "string"
        },
        "observable": {
          "minLength": 1,
          "title": "Observable",
          "type": "string"
        }
      },
      "required": [
        "observable",
        "comparator_or_threshold",
        "evidence_needed"
      ],
      "title": "SuccessCheck",
      "type": "object"
    },
    "TargetProperty": {
      "enum": [
        "executability",
        "specification_compliance",
        "task_performance",
        "correctness_or_formal_validity",
        "empirical_adequacy",
        "reproducibility",
        "novelty",
        "significance",
        "aggregate_quality",
        "not_reported"
      ],
      "title": "TargetProperty",
      "type": "string"
    },
    "ValidatorChannel": {
      "additionalProperties": false,
      "properties": {
        "channel_id": {
          "minLength": 1,
          "title": "Channel Id",
          "type": "string"
        },
        "decision_role": {
          "items": {
            "$ref": "#/$defs/DecisionRole"
          },
          "title": "Decision Role",
          "type": "array"
        },
        "evaluator_substrate": {
          "items": {
            "$ref": "#/$defs/EvaluatorSubstrate"
          },
          "title": "Evaluator Substrate",
          "type": "array"
        },
        "evidence_source": {
          "items": {
            "$ref": "#/$defs/EvidenceSource"
          },
          "title": "Evidence Source",
          "type": "array"
        },
        "experimental_fidelity": {
          "items": {
            "$ref": "#/$defs/Fidelity"
          },
          "title": "Experimental Fidelity",
          "type": "array"
        },
        "external_independence": {
          "$ref": "#/$defs/ExternalIndependence"
        },
        "feedback_path": {
          "items": {
            "$ref": "#/$defs/FeedbackPath"
          },
          "title": "Feedback Path",
          "type": "array"
        },
        "operational_status": {
          "$ref": "#/$defs/OperationalStatus"
        },
        "quotes": {
          "items": {
            "$ref": "#/$defs/EvidenceQuote"
          },
          "minItems": 1,
          "title": "Quotes",
          "type": "array"
        },
        "reliability_evidence_type": {
          "items": {
            "$ref": "#/$defs/ReliabilityEvidence"
          },
          "title": "Reliability Evidence Type",
          "type": "array"
        },
        "reliability_finding": {
          "$ref": "#/$defs/ReliabilityFinding"
        },
        "target_property": {
          "items": {
            "$ref": "#/$defs/TargetProperty"
          },
          "title": "Target Property",
          "type": "array"
        }
      },
      "required": [
        "channel_id",
        "operational_status",
        "target_property",
        "evidence_source",
        "evaluator_substrate",
        "decision_role",
        "feedback_path",
        "external_independence",
        "reliability_evidence_type",
        "reliability_finding",
        "experimental_fidelity",
        "quotes"
      ],
      "title": "ValidatorChannel",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "channels": {
      "items": {
        "$ref": "#/$defs/ValidatorChannel"
      },
      "minItems": 1,
      "title": "Channels",
      "type": "array"
    },
    "envelope": {
      "$ref": "#/$defs/CommonEnvelope"
    },
    "human_authority": {
      "$ref": "#/$defs/HumanAuthority"
    },
    "memory_structure": {
      "items": {
        "type": "string"
      },
      "title": "Memory Structure",
      "type": "array"
    },
    "model_id": {
      "minLength": 1,
      "title": "Model Id",
      "type": "string"
    },
    "policy_type": {
      "items": {
        "type": "string"
      },
      "title": "Policy Type",
      "type": "array"
    },
    "record_id": {
      "pattern": "^R\\d{2}$",
      "title": "Record Id",
      "type": "string"
    },
    "vendor": {
      "minLength": 1,
      "title": "Vendor",
      "type": "string"
    }
  },
  "required": [
    "record_id",
    "vendor",
    "model_id",
    "channels",
    "policy_type",
    "memory_structure",
    "human_authority",
    "envelope"
  ],
  "title": "ServoCoding",
  "type": "object"
}