{
  "$defs": {
    "CommonEnvelope": {
      "additionalProperties": false,
      "properties": {
        "diagnostics": {
          "items": {
            "$ref": "#/$defs/Diagnostic"
          },
          "title": "Diagnostics",
          "type": "array"
        },
        "recommendations": {
          "items": {
            "$ref": "#/$defs/Recommendation"
          },
          "maxItems": 3,
          "minItems": 1,
          "title": "Recommendations",
          "type": "array"
        }
      },
      "required": [
        "diagnostics",
        "recommendations"
      ],
      "title": "CommonEnvelope",
      "type": "object"
    },
    "Diagnostic": {
      "additionalProperties": false,
      "properties": {
        "consequence": {
          "minLength": 1,
          "title": "Consequence",
          "type": "string"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Evidence Ids",
          "type": "array"
        },
        "exact_quotes": {
          "items": {
            "$ref": "#/$defs/EvidenceExcerpt"
          },
          "minItems": 1,
          "title": "Exact Quotes",
          "type": "array"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/DiagnosticKind"
        },
        "statement": {
          "minLength": 1,
          "title": "Statement",
          "type": "string"
        }
      },
      "required": [
        "id",
        "statement",
        "kind",
        "evidence_ids",
        "exact_quotes",
        "consequence"
      ],
      "title": "Diagnostic",
      "type": "object"
    },
    "DiagnosticKind": {
      "enum": [
        "reported_failure",
        "risk",
        "ambiguity",
        "missing_evidence"
      ],
      "title": "DiagnosticKind",
      "type": "string"
    },
    "EvidenceExcerpt": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "exact_quote": {
          "minLength": 1,
          "title": "Exact Quote",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "exact_quote"
      ],
      "title": "EvidenceExcerpt",
      "type": "object"
    },
    "Recommendation": {
      "additionalProperties": false,
      "properties": {
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Evidence Ids",
          "type": "array"
        },
        "exact_quotes": {
          "items": {
            "$ref": "#/$defs/EvidenceExcerpt"
          },
          "minItems": 1,
          "title": "Exact Quotes",
          "type": "array"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "linked_diagnostic_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Linked Diagnostic Ids",
          "type": "array"
        },
        "priority_rank": {
          "maximum": 3,
          "minimum": 1,
          "title": "Priority Rank",
          "type": "integer"
        },
        "proposed_action": {
          "minLength": 1,
          "title": "Proposed Action",
          "type": "string"
        },
        "success_check": {
          "$ref": "#/$defs/SuccessCheck"
        }
      },
      "required": [
        "id",
        "priority_rank",
        "proposed_action",
        "linked_diagnostic_ids",
        "evidence_ids",
        "exact_quotes",
        "success_check"
      ],
      "title": "Recommendation",
      "type": "object"
    },
    "SuccessCheck": {
      "additionalProperties": false,
      "properties": {
        "comparator_or_threshold": {
          "minLength": 1,
          "title": "Comparator Or Threshold",
          "type": "string"
        },
        "evidence_needed": {
          "minLength": 1,
          "title": "Evidence Needed",
          "type": "string"
        },
        "observable": {
          "minLength": 1,
          "title": "Observable",
          "type": "string"
        }
      },
      "required": [
        "observable",
        "comparator_or_threshold",
        "evidence_needed"
      ],
      "title": "SuccessCheck",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "envelope": {
      "$ref": "#/$defs/CommonEnvelope"
    },
    "memo": {
      "minLength": 1,
      "title": "Memo",
      "type": "string"
    },
    "model_id": {
      "minLength": 1,
      "title": "Model Id",
      "type": "string"
    },
    "record_id": {
      "pattern": "^R\\d{2}$",
      "title": "Record Id",
      "type": "string"
    },
    "vendor": {
      "minLength": 1,
      "title": "Vendor",
      "type": "string"
    }
  },
  "required": [
    "record_id",
    "vendor",
    "model_id",
    "memo",
    "envelope"
  ],
  "title": "BaselineCoding",
  "type": "object"
}